# NVIDIA CUDA base image with PyTorch support (stable)
FROM nvidia/cuda:12.1.1-cudnn8-devel-ubuntu22.04

# Avoid interactive prompts
ENV DEBIAN_FRONTEND=noninteractive
ENV CUDA_HOME=/usr/local/cuda
ENV PATH="${CUDA_HOME}/bin:${PATH}"
ENV LD_LIBRARY_PATH="${CUDA_HOME}/lib64:${LD_LIBRARY_PATH}"

# System dependencies
RUN apt-get update && apt-get install -y \
    git wget curl python3.10 python3.10-dev python3-pip \
    build-essential ninja-build htop vim tmux \
    && rm -rf /var/lib/apt/lists/*

# Set Python 3.10 as default
RUN update-alternatives --install /usr/bin/python python /usr/bin/python3.10 1 && \
    update-alternatives --install /usr/bin/pip pip /usr/bin/pip3 1

# Upgrade pip
RUN pip install --upgrade pip

# Working directory
WORKDIR /workspace

# Install PyTorch (CUDA 12.1)
RUN pip install torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu121

# Build dependencies
RUN pip install packaging ninja wheel setuptools setuptools-scm

# Clone HRM repo
RUN git clone https://github.com/sapientinc/HRM.git /workspace/hrm
WORKDIR /workspace/hrm

# Initialize submodules
# Initialize submodules (force HTTPS instead of SSH)
RUN git config --global url."https://github.com/".insteadOf "git@github.com:" && \
    git submodule update --init --recursive


# Install FlashAttention 2 (Ampere compatible)
# Fix setuptools & psutil before FlashAttention
RUN pip install --upgrade pip setuptools setuptools-scm wheel ninja packaging psutil && \
    pip install flash-attn --no-build-isolation || echo "⚠️ FlashAttention kurulumu atlandı"


# Project requirements
RUN pip install -r requirements.txt

# Weights & Biases
RUN pip install wandb

# Performance tuning
ENV OMP_NUM_THREADS=12
ENV PYTHONUNBUFFERED=1

# Optional W&B port
EXPOSE 8080

# Default command
CMD ["/bin/bash"]
